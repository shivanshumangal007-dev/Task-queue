{
	"name": "task-queue",
	"version": "1.0.0",
	"description": "Redis-backed task queue with Express API, worker, and React dashboard",
	"main": "server.js",
	"type": "module",
	"scripts": {
		"test": "echo \"No tests configured yet\"",
		"start": "node server.js",
		"dev": "nodemon server.js",
		"worker": "nodemon ./worker/worker.js",
		"worker:start": "node ./worker/worker.js",
		"frontend:dev": "npm --prefix ./frontend_for_task_queue run dev",
		"frontend:build": "npm --prefix ./frontend_for_task_queue run build",
		"frontend:lint": "npm --prefix ./frontend_for_task_queue run lint"
	},
	"author": "",
	"license": "ISC",
	"dependencies": {
		"cors": "^2.8.6",
		"dotenv": "^17.3.1",
		"express": "^5.2.1",
		"redis": "^5.11.0",
		"uuid": "^13.0.0"
	},
	"devDependencies": {
		"nodemon": "^3.1.10"
	}
}
